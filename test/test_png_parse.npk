use "../src/png.npk".*;
use "../src/errors.npk".*;

pub func:failsafe = int32(tbb32:err) { drop(err);
    exit(1i32);
};

pub func:main = int32() {
    drop(png_check_signature(0i64));
    
    PngHeader:header = PngHeader{
        width: 0i32,
        height: 0i32,
        bit_depth: 0i32,
        color_type: 0i32,
        compression_method: 0i32,
        filter_method: 0i32,
        interlace_method: 0i32
    };
    drop(png_parse_ihdr(@header, 0i64));
    
    PngChunkReader:reader = PngChunkReader{data: 0i64, len: 0i64, pos: 0i64};
    drop(pngchunkreader_init(@reader, 0i64, 100i64));
    drop(pngchunkreader_next_chunk(@reader, 0i64, 0i64, 0i64));
    
    drop(header);
    drop(reader);
    
    exit(0i32);
};
